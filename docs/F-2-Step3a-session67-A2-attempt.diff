+		     p <= (ptr_t)D_A(PDLPTR); p += 3*DESCR) {
+		    pslot1 = p + DESCR;
+		    if (!(D_F(pslot1) & FNC)) {
+			D_A(pslot1) = 0;
+			D_F(pslot1) = 0;
+			D_V(pslot1) = 0;
+		    }
+		}
+	    }
+	}
+    }
