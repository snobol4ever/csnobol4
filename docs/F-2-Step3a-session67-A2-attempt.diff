+    /* session #67 option A2: zero non-FNC slot[1]s in the leak region IF any
+     * FNCDCL exists anywhere in the active PDL frame [PDLHED..PDLPTR].
+     * This catches FENCE-involved scopes even when the FNCDCL lives in an
+     * outer STARP2's region. Conditional on FNCDCL presence to preserve
+     * guard5 (no FENCE -> no FNCDCL -> no zeroing -> DSAR-redo alt-conts
+     * survive for inner-backtrack). Closes Cluster B (test 124). Cluster A
+     * (119/129/148/149) requires a different fix — see session #67 findings. */
+    if (D_A(PDLPTR) > D_A(STREX_entrypdl)) {
+	{
+	    ptr_t pslot1;
+	    ptr_t p;
+	    int fncdcl_found = 0;
+	    /* scan from PDLHED to PDLPTR for any FNCDCL */
+	    for (p = (ptr_t)D_A(PDLHED); p <= (ptr_t)D_A(PDLPTR); p += 3*DESCR) {
+		pslot1 = p + DESCR;
