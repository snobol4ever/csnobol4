*----------------------------------------------------------------------
* test/fence_function/t04_optional_suffix.sno
* Real-world idiom from corpus (expression.sno, beauty suite):
*   FENCE(SPAN(digits) | '')
* This is "match digits if present, commit, don't retry".
* Used everywhere in the corpus for optional token suffixes.
*
* Key property: matches digits greedily, or matches empty string,
* and commits to whichever it chose. No backtracking back to try
* the other alternative.
*----------------------------------------------------------------------
               digits = '0123456789'

*   Case 1: digits present -> FENCE matches them, returns them
               S1 = '123abc'
               S1  FENCE(SPAN(digits) | '')  . matched         :F(FAIL1)
               OUTPUT = EQ(matched, '123') 'PASS t04a: digits matched = ' matched
                                                               :S(CASE2)
               OUTPUT = 'FAIL t04a: expected 123, got ' matched :(END)

FAIL1          OUTPUT = 'FAIL t04a: match failed entirely'     :(END)

*   Case 2: no digits -> FENCE matches empty string
CASE2          S2 = 'abc'
               S2  POS(0) FENCE(SPAN(digits) | '') . matched   :F(FAIL2)
               OUTPUT = EQ(SIZE(matched), 0) 'PASS t04b: empty match when no digits'
                                                               :S(END)
               OUTPUT = 'FAIL t04b: expected empty, got [' matched ']'
                                                               :(END)
FAIL2          OUTPUT = 'FAIL t04b: match failed entirely'
END
